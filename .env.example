# OPENAI_API_KEY: Local development uses this for Codex / OpenAI-compatible testing, defaulting to gpt-5.4.
OPENAI_API_KEY=

# OPENAI_BASE_URL: Optional for local-only routing. Leave blank for the normal local path unless you are explicitly testing an online gateway.
OPENAI_BASE_URL=

# OPENAI_MODEL: Optional. Defaults to gpt-5.4 locally.
OPENAI_MODEL=gpt-5.4

# YUNWU_API_KEY: Production can use this for the unified 云雾 OpenAI-compatible gateway.
YUNWU_API_KEY=

# YUNWU_BASE_URL: Production default is https://yunwu.ai/v1.
YUNWU_BASE_URL=https://yunwu.ai/v1

# YUNWU_MODEL: Production default model.
YUNWU_MODEL=claude-sonnet-4-5-20250929-thinking

# GEMINI_API_KEY: Optional. Used as fallback for analysis and for image/PDF recognition.
GEMINI_API_KEY=

# GEMINI_MODEL: Optional. Defaults to gemini-2.5-flash.
GEMINI_MODEL=gemini-2.5-flash

# SILICONFLOW_API_KEY: Optional. Used for SiliconFlow OpenAI-compatible chat completions.
SILICONFLOW_API_KEY=

# SILICONFLOW_BASE_URL: Optional. Defaults to SiliconFlow official OpenAI-compatible endpoint.
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# SILICONFLOW_MODEL: Optional. Railway can point this to your configured SiliconFlow model.
SILICONFLOW_MODEL=Qwen/Qwen3.5-397B-A17B

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=

# DATABASE_URL: Closed-loop analysis mode only reads this variable and will not fall back to POSTGRES_URL or memory storage in normal runtime.
# Recommended for Railway production databases or a hosted Postgres such as Neon. For local Postgres you can append ?sslmode=disable.
DATABASE_URL=

# CLOSED_LOOP_API_TOKEN: Protects production api/closed-loop/* endpoints.
# Clients can send it via Authorization: Bearer <token>, x-api-key, or x-closed-loop-token.
CLOSED_LOOP_API_TOKEN=

# CLOSED_LOOP_REQUIRE_AUTH: Force auth even outside production. Set to 1 when you want local/staging to enforce closed-loop API auth.
CLOSED_LOOP_REQUIRE_AUTH=0

# CLOSED_LOOP_READ_ROLES: Roles allowed to read jobs and snapshots.
CLOSED_LOOP_READ_ROLES=analyst,reviewer,operator,manager,admin

# CLOSED_LOOP_REVIEW_ROLES: Roles allowed to read review queues/search and submit review decisions.
CLOSED_LOOP_REVIEW_ROLES=reviewer,operator,admin

# CLOSED_LOOP_WRITE_ROLES: Roles allowed to import closed-loop workbooks.
CLOSED_LOOP_WRITE_ROLES=operator,admin

# VITE_CLOSED_LOOP_API_TOKEN: Browser-side token used by the first-party app to call api/closed-loop/* in production.
# This is a temporary production bridge until a real user/session auth system is introduced.
VITE_CLOSED_LOOP_API_TOKEN=

# VITE_CLOSED_LOOP_USER_ROLE: Browser-side role sent with the closed-loop token.
VITE_CLOSED_LOOP_USER_ROLE=operator
